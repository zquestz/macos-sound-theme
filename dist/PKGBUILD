# Maintainer: Josh Ellithorpe <quest@mac.com

pkgname=macos-sound-theme
pkgver=r9.b143332
pkgrel=1
pkgdesc='MacOS trash sounds for Linux.'
arch=(any)
url=https://github.com/zquestz/macos-sound-theme
license=(MIT)
makedepends=(
  git
  meson
)
source=(macos-sound-theme::git+https://github.com/zquestz/macos-sound-theme.git)
sha256sums=('SKIP')

pkgver() {
  cd macos-sound-theme
  printf 'r%s.%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  arch-meson macos-sound-theme build
  ninja -C build
}

package() {
  DESTDIR="${pkgdir}" ninja -C build install
}
